CANDLE_DB_HOST=localhost
CANDLE_DB_PORT=5432
CANDLE_DB_USER=simpler
CANDLE_DB_PASSWORD=simpler_pass
CANDLE_DB_NAME=simpler_trader
CANDLE_DB_SSLMODE=prefer
CANDLE_DB_MIN_POOL_SIZE=2
CANDLE_DB_MAX_POOL_SIZE=20
CANDLE_DB_CONNECT_TIMEOUT=10
CANDLE_DB_MAX_IDLE_SECONDS=300

# Alternative single-URL form. If set, this takes precedence over the fields above.
# CANDLE_DATABASE_URL=postgresql://simpler:simpler_pass@localhost:5432/simpler_trader

# Optional Binance/candle download proxy defaults for the web UI.
# WEB_CANDLE_PROXY applies to both HTTP and HTTPS when the specific value is omitted.
# WEB_CANDLE_PROXY=http://127.0.0.1:7890
# WEB_CANDLE_HTTP_PROXY=http://127.0.0.1:7890
# WEB_CANDLE_HTTPS_PROXY=http://127.0.0.1:7890
