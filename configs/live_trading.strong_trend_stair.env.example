# Live Trading Config (Strong Trend Stair Trailing)
# Copy to: configs/live_trading.strong_trend_stair.env

# Exchange
EXCHANGE=bitunix
TRADING_MODE=futures
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=
TESTNET=true

# Strategy
STRATEGY_NAME=strong_trend_stair
TIMEFRAME=1m
SYMBOL=ETHUSDT

# Core behavior
# Fixed by strategy implementation:
#   leverage=100x
#   margin_mode=cross
#   trade_notional_usd=100 (about $1 margin at 100x)
TICK_INTERVAL_SECONDS=1.0
HARD_STOP_LOSS_PCT=5.0
TRAIL_START_PCT=2.0
TRAIL_OFFSET_PCT=1.0
REVERSE_ON_OPPOSITE_SIGNAL=false

# Trend filter params (matching Pine defaults)
EMA_FAST_LEN=50
EMA_MID_LEN=100
EMA_SLOW_LEN=200
SLOPE_LOOKBACK=10
ST_ATR_LEN=10
ST_FACTOR=3.0
DI_LEN=14
ADX_SMOOTH=14
ADX_MIN=20.0

# Persistence / logging
KLINES_DB=./configs/live_trading.strong_trend_stair.env
LOG_FILE=./logs/live_trading.log

# Telegram
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_PROXY=
# TELEGRAM_TIMEOUT=10.0

# Optional
# EXCHANGE_BASE_URL=
# HTTP_PROXY=
# HTTPS_PROXY=
# PROXY=
