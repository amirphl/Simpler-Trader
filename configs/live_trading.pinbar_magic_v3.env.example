# Live Trading Config (PinBar Magic v3)
# Copy to: configs/live_trading.pinbar_magic_v3.env

# Exchange
EXCHANGE=bitunix
TRADING_MODE=futures
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=
TESTNET=true

# Strategy
STRATEGY_NAME=pinbar_magic_v3
TIMEFRAME=5m
PINBAR_SYMBOLS=ETHUSDT

# PinBar Magic v3
LEVERAGE=2
EQUITY_RISK_PCT=0.25
ATR_MULTIPLE=1.0
TRAIL_POINTS=800
TRAIL_OFFSET=600
SYMBOL_MINTICK=0.01
SLOW_SMA_PERIOD=200
MEDIUM_EMA_PERIOD=72
FAST_EMA_PERIOD=24
ATR_PERIOD=56
ENTRY_CANCEL_BARS=4
ENTRY_ACTIVATION_MODE=next_bar
TRAILING_TICK_TIMEFRAME=1m
USE_TRAILING_TICK_EMULATION=true
USE_STOP_FILL_OPEN_GAP=true
ENABLE_FRIDAY_CLOSE=false
FRIDAY_CLOSE_HOUR_UTC=16
ENABLE_EMA_CROSS_CLOSE=true
RISK_EQUITY_INCLUDE_UNREALIZED=false
RISK_EQUITY_MARK_SOURCE=close
POLL_INTERVAL_SECONDS=2.0
TRAILING_CHECK_INTERVAL_SECONDS=2.0

# Risk / Positions
MARGIN_MODE=isolated
POSITION_SIZE_USDT=100.0
MAX_ENTRY_NOTIONAL_USDT=50.0
MAX_CONCURRENT_POSITIONS=1
MAX_POSITION_SIZE_PCT=10.0
DISABLE_SYMBOL_HOURS=0

# Persistence
STATE_FILE=./data/pinbar_magic_v3_live_trading_state.json
POSITIONS_DB=./data/pinbar_magic_v3_live_trading_positions.db
# Optional .env file for candle PostgreSQL settings (CANDLE_DB_* / POSTGRES_*).
KLINES_DB=./configs/live_trading.pinbar_magic_v3.env
LOG_FILE=./logs/live_trading.pinbar_magic_v3.log

# Optional
# EXCHANGE_BASE_URL=
# HTTP_PROXY=
# HTTPS_PROXY=
# PROXY=

# Telegram
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_PROXY=
# TELEGRAM_TIMEOUT=10.0
