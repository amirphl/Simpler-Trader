# Live Trading Config (EMA + AVWAP Pullback)
# Copy to: configs/live_trading.ema_avwap_pullback.env

# Exchange
EXCHANGE=bitunix
TRADING_MODE=futures
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=
TESTNET=true

# Strategy
STRATEGY_NAME=ema_avwap_pullback
TIMEFRAME=5m
SYMBOLS=ETHUSDT

# EMA + AVWAP Pullback
LEVERAGE=2
EQUITY_RISK_PCT=0.25
EMA_LENGTH=55
CONSECUTIVE_COUNT=4
EMA_VALIDATION_MODE=body
SETUP_WAITING_REPLACEMENT_MODE=keep_waiting
POSITION_SIZING_MODE=risk_distance
AVWAP_MULTIPLIER_1=1.0
AVWAP_MULTIPLIER_2=2.0
AVWAP_MULTIPLIER_3=3.0
RIGID_STOP_LOSS_PCT=0.0
TRAILING_ACTIVATION_THRESHOLD_PCT=0.0
TRAILING_GAP_PCT=1.0
MAKER_FEE_PCT=0.0002
TAKER_FEE_PCT=0.0006
ENTRY_SLIPPAGE_PCT=0.0
EXIT_SLIPPAGE_PCT=0.0
USE_GAP_CROSS_DETECTION=true

# Live execution safety
ENTRY_CANCEL_BARS=1
MAX_HISTORY_BARS=512
MINIMUM_BALANCE_USDT=0.0
API_RETRIES=3
API_RETRY_DELAY_SECONDS=1.0
EMERGENCY_CLOSE_ON_STOP_FAILURE=true
ALLOW_DYNAMIC_STOP_WIDENING=true
MIN_STOP_UPDATE_PCT=0.0
POLL_INTERVAL_SECONDS=2.0
TRAILING_CHECK_INTERVAL_SECONDS=2.0
TRAILING_TICK_TIMEFRAME=1m
USE_TRAILING_TICK_EMULATION=false

# Risk / Positions
MARGIN_MODE=isolated
POSITION_SIZE_USDT=100.0
MAX_ENTRY_NOTIONAL_USDT=50.0
MAX_CONCURRENT_POSITIONS=1
MAX_POSITION_SIZE_PCT=10.0
DISABLE_SYMBOL_HOURS=0

# Persistence
STATE_FILE=./data/ema_avwap_pullback_live_trading_state.json
POSITIONS_DB=./data/ema_avwap_pullback_live_trading_positions.db
KLINES_DB=./configs/live_trading.ema_avwap_pullback.env
LOG_FILE=./logs/live_trading.ema_avwap_pullback.log

# Optional
# EXCHANGE_BASE_URL=
# If HTTPS_PROXY is empty, HTTP_PROXY is also used for HTTPS exchange API
# and Binance fallback requests.
# HTTP_PROXY=
# HTTPS_PROXY=
# PROXY=

# Telegram
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_PROXY=
# TELEGRAM_TIMEOUT=10.0
