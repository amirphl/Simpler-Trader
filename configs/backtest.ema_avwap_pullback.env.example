BACKTEST_STRATEGY=ema_avwap_pullback

STRATEGY_SYMBOL=ETHUSDT
STRATEGY_TIMEFRAME=1h
STRATEGY_LEVERAGE=1
STRATEGY_EQUITY_RISK_PCT=1
STRATEGY_EMA_LENGTH=55
STRATEGY_CONSECUTIVE_COUNT=4
STRATEGY_EMA_VALIDATION_MODE=body
STRATEGY_SETUP_WAITING_REPLACEMENT_MODE=keep_waiting
STRATEGY_POSITION_SIZING_MODE=risk_distance
STRATEGY_AVWAP_MULTIPLIER_1=1.0
STRATEGY_AVWAP_MULTIPLIER_2=2.0
STRATEGY_AVWAP_MULTIPLIER_3=3.0
STRATEGY_RIGID_STOP_LOSS_PCT=0
STRATEGY_TRAILING_ACTIVATION_THRESHOLD_PCT=0
STRATEGY_TRAILING_GAP_PCT=1.0
STRATEGY_MAKER_FEE_PCT=0.0002
STRATEGY_TAKER_FEE_PCT=0.0006
STRATEGY_ENTRY_SLIPPAGE_PCT=0
STRATEGY_EXIT_SLIPPAGE_PCT=0
STRATEGY_USE_GAP_CROSS_DETECTION=true
STRATEGY_MAX_DECISION_LOG_ENTRIES=20000

BACKTEST_START=2025-01-01T00:00:00Z
BACKTEST_END=2025-03-31T23:59:59Z
BACKTEST_INITIAL_CAPITAL=10000
BACKTEST_WARMUP_DAYS=30
OVERRIDE_DOWNLOAD=false

STORE_KIND=postgres
# Optional .env file for candle PostgreSQL settings (CANDLE_DB_* / POSTGRES_*).
STORE_PATH=
STATS_OUTPUT=./backtest_stats.ema_avwap_pullback.json
PLOT_OUTPUT=
SHOW_PLOT=false
SHOW_STOCHASTIC=false
SHOW_EQUITY=true
LOG_LEVEL=INFO
